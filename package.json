{
  "name": "genkey-cli",
  "version": "1.1.2",
  "description": "CLI tool to generate secret keys and UUIDs directly from your terminal.",
  "keywords": [
    "cli",
    "cryptography",
    "generator",
    "secret-key",
    "security",
    "terminal",
    "uuid"
  ],
  "license": "MIT",
  "author": "Carlos Acosta",
  "bin": {
    "gen": "dist/index.js",
    "genkey-cli": "dist/index.js"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "fmt": "oxfmt",
    "lint": "oxlint",
    "build": "tsc",
    "start": "node dist/index.js",
    "publish:npm": "pnpm build && npm publish --access public"
  },
  "dependencies": {
    "clipboardy": "^5.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.30.3"
